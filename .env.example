# URL for the imgproxy server
IMGPROXY_URL=http://imgproxy:8080

# This will only allow images from example.com and coolify.io to be resized.
# use "*" to allow all domains
ALLOWED_REMOTE_DOMAINS=example.com,coolify.io

# Optional: rewrite source image URLs before forwarding to imgproxy.
# Example: https://ny-1s.enzonix.com/bucket-1286-1793/uploads/a.jpg -> https://xxx.com/uploads/a.jpg
SOURCE_REWRITE_FROM=https://ny-1s.enzonix.com/bucket-1286-1793
SOURCE_REWRITE_TO=https://xxx.com
